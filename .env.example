# Default model used when the request doesn't specify "model"
CODEX_MODEL=gpt-5.4-mini

# Models listed by GET /v1/models (comma-separated). Optional — overrides the
# built-in list so it survives OpenAI model updates. Cosmetic: does NOT restrict
# which model you can actually call.
# CODEX_MODELS=gpt-5.5,gpt-5.4,gpt-5.4-mini

# Default reasoning sent to the backend
CODEX_REASONING_EFFORT=medium
CODEX_REASONING_SUMMARY=auto

# Backend timeout in seconds
BACKEND_TIMEOUT=600

# Log every backend SSE event (debug)
PROXY_DEBUG_EVENTS=0

# Proxy port (host). The container always listens on 5001.
PROXY_PORT=5001

# If set, every request needs "Authorization: Bearer <key>"
PROXY_API_KEY=
